generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuditGroup {
  ADMIN
  USER
}

enum ObservationStatus {
  ACTIVE
  REVIEWED
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PaymentMethod {
  id        String    @id @default(cuid())
  name      String    @unique
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Permission {
  id              String            @id @default(cuid())
  name            String            @unique
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Role {
  id              String            @id @default(cuid())
  name            String            @unique
  description     String?
  users           User[]
  rolePermissions RolePermission[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model RolePermission {
  roleId       String
  permissionId  String
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  grantedAt    DateTime    @default(now())

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  password  String
  email     String    @unique
  roleId    String
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  expenses  Expense[]
  auditLogs AuditLog[]
  observationList ObservationList?
  // Authentication fields
  passwordResetToken   String?
  passwordResetExpires DateTime?
  twoFactorEnabled     Boolean   @default(false)
  totpSecret           String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([roleId])
}

model Expense {
  id              String        @id @default(cuid())
  title           String
  amount          Decimal       @db.Decimal(12, 2)
  date            DateTime
  notes           String?
  userId          String?
  categoryId      String
  paymentMethodId String
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([paymentMethodId])
  @@index([date])
}

model AuditLog {
  logId             String      @id @default(cuid()) @map("LogID")
  userId            String      @map("UserID")
  groupId           AuditGroup  @map("GroupID")
  actionInformation Json        @map("ActionInformation")
  timestamp         DateTime    @default(now()) @map("Timestamp")
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([groupId])
  @@index([timestamp])
  @@map("AuditLogs")
}

model ObservationList {
  flagId        String             @id @default(cuid()) @map("FlagID")
  userId        String             @unique @map("UserID")
  reason        String             @map("Reason")
  severityLevel Int                @default(1) @map("SeverityLevel")
  status        ObservationStatus  @default(ACTIVE) @map("Status")
  flaggedAt     DateTime           @default(now()) @map("FlaggedAt")
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([status])
  @@index([severityLevel])
  @@index([flaggedAt])
  @@map("ObservationList")
}

