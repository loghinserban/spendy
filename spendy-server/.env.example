PORT=3000
DATABASE_URL="postgresql://postgres:password@localhost:5432/spendy_db?schema=public"
MONGO_URI="mongodb://localhost:27017/spendy-chat"

# JWT configuration
JWT_SECRET=your-very-long-random-secret
JWT_EXPIRES_IN=1h

# Auth brute-force protection
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Optional app base URL for reset links
APP_BASE_URL=https://localhost:3000

# Optional single frontend origin alias (alternative to CORS_ORIGINS)
# FRONTEND_ORIGIN=https://localhost:5173

# Explicit frontend origins allowed by CORS and WebSocket origin checks
# Required for this lab setup:
# CORS_ORIGINS=https://localhost:5173,https://10.139.107.33:5173
CORS_ORIGINS=https://localhost:5173,https://10.139.107.33:5173

# Optional SMTP settings (if omitted, a dev transporter is used)
SMTP_FROM=spendy@example.local
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# HTTPS certificate paths used by the backend server
# The server will auto-generate PEM files here if they are missing.
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem
