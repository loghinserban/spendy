PORT=3000
NODE_ENV=development
USE_SELF_SIGNED_HTTPS=true

# Database: PostgreSQL (Neon)
DATABASE_URL=postgresql://neondb_owner:npg_6wrgdtS0GODW@ep-curly-mouse-apon30cm.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require

# Database: MongoDB (Atlas) - Ensure Render's IP is whitelisted in MongoDB Atlas Network Access
MONGO_URI=mongodb+srv://spendy_admin:password_admin@spendy.9iln5yn.mongodb.net/?appName=spendy

# JWT configuration
JWT_SECRET=your-very-long-random-secret
JWT_EXPIRES_IN=1h

# Auth brute-force protection
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Optional app base URL for reset links
APP_BASE_URL=https://localhost:3000

# Explicit frontend origins allowed by CORS and WebSocket origin checks
# Production: https://spendy-qrxfrhjaj-serban-spendy.vercel.app
CORS_ORIGINS=https://localhost:5173,https://10.139.107.33:5173,https://spendy-qrxfrhjaj-serban-spendy.vercel.app

# Frontend Origin (used for cookie settings and redirects)
FRONTEND_ORIGIN=https://spendy-qrxfrhjaj-serban-spendy.vercel.app

# Cookie settings for cross-origin requests
AUTH_COOKIE_SAMESITE=lax

# Optional SMTP settings (if omitted, a dev transporter is used)
SMTP_FROM=spendy@example.local
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# HTTPS certificate paths used by the backend server
# The server will auto-generate PEM files here if they are missing.
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem

# Seeding configuration
SEED_ADMIN_PASSWORD=passadmin

# Request size limits (in bytes)
REQUEST_BODY_LIMIT_BYTES=65536

